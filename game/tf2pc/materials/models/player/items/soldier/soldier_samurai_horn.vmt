"VertexlitGeneric"
{
	$baseTexture "models/player/items/soldier/soldier_samurai_horn.vtf"
//	"$additive"	1

	"$envmap" "env_cubemap"
	"$envmaptint" "[.3 .3 .2]"
	"$yellow" "0"
	"$phong" "1"
	"$phongexponent" "25"
	"$phongboost" "2"
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"	
	"$phongfresnelranges"	"[.25 1 4]"
	"$basemapalphaphongmask" "1"

	"$rimlight" "1"						
	"$rimlightexponent" "60"				
	"$rimlightboost" "5"


	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"weapon_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 30
		}
		"BurnLevel"
		{
			"resultVar" "$detailblendfactor"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Equals"
		{
			"srcVar1"  "$yellow"
			"resultVar" "$color2"
		}

	}
}


